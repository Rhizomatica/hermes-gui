{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "projects": {
    "hermes": {
      "projectType": "application",
      "root": "",
      "sourceRoot": "src",
      "prefix": "app",
      "i18n": {
        "sourceLocale": "en-US",
        "locales": {
          "pt": "src/locale/messages.pt.xlf",
          "es": "src/locale/messages.es.xlf",
          "fr": "src/locale/messages.fr.xlf",
          "ar": "src/locale/messages.ar.xlf"
        }
      },
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:application",
          "options": {
            "localize": [
              "en-US",
              "pt",
              "es",
              "fr",
              "ar"
            ],
            "outputPath": {
              "base": "dist/hermes"
            },
            "index": "src/index.html",
            "polyfills": [
              "zone.js",
              "@angular/localize/init"
            ],
            "tsConfig": "tsconfig.app.json",
            "assets": [
              "src/favicon.ico",
              "src/assets",
              "src/manifest.webmanifest"
            ],
            "styles": [
              "src/styles/styles.less"
            ],
            "serviceWorker": "ngsw-config.json",
            "allowedCommonJsDependencies": [
              "polylabel",
              "recordrtc"
            ],
            "browser": "src/main.ts"
          },
          "configurations": {
            "production": {
              "aot": true,
              "optimization": true,
              "outputHashing": "all",
              "sourceMap": false,
              "namedChunks": false,
              "extractLicenses": true,
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "2mb",
                  "maximumError": "5mb"
                }
              ]
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true,
              "namedChunks": true
            },
            "pt": {
              "localize": [
                "pt"
              ],
              "optimization": false,
              "sourceMap": true,
              "extractLicenses": false,
              "namedChunks": true
            },
            "es": {
              "localize": [
                "es"
              ],
              "optimization": false,
              "sourceMap": true,
              "extractLicenses": false,
              "namedChunks": true
            },
            "fr": {
              "localize": [
                "fr"
              ],
              "optimization": false,
              "sourceMap": true,
              "extractLicenses": false,
              "namedChunks": true
            },
            "ar": {
              "localize": [
                "ar"
              ],
              "optimization": false,
              "sourceMap": true,
              "extractLicenses": false,
              "namedChunks": true
            }
          }
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "options": {
            "buildTarget": "hermes:build"
          },
          "configurations": {
            "production": {
              "buildTarget": "hermes:build:production"
            },
            "development": {
              "buildTarget": "hermes:build:development"
            },
            "pt": {
              "buildTarget": "hermes:build:development,pt"
            },
            "es": {
              "buildTarget": "hermes:build:development,es"
            },
            "fr": {
              "buildTarget": "hermes:build:development,fr"
            },
            "ar": {
              "buildTarget": "hermes:build:development,ar"
            }
          }
        },
        "extract-i18n": {
          "builder": "@angular-devkit/build-angular:extract-i18n",
          "options": {
            "buildTarget": "hermes:build",
            "outputPath": "src/locale"
          }
        },
        "test": {
          "builder": "@angular-devkit/build-angular:karma",
          "options": {
            "main": "src/test.ts",
            "polyfills": [
              "zone.js",
              "@angular/localize/init"
            ],
            "tsConfig": "tsconfig.spec.json",
            "karmaConfig": "karma.conf.js",
            "assets": [
              "src/favicon.png",
              "src/assets"
            ],
            "styles": [
              "src/styles/styles.less"
            ]
          }
        }
      }
    }
  },
  "cli": {
    "analytics": false
  }
}